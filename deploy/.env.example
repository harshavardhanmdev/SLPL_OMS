# ============================================================
#  SLPL Store - production environment
#  Copy to deploy/.env on the server and fill in. NEVER commit .env.
# ============================================================

# ── Database (containers talk over the internal docker network) ──
POSTGRES_USER=oms
POSTGRES_PASSWORD=CHANGE-ME-long-random-password
POSTGRES_DB=oms
DATABASE_URL=postgresql://oms:CHANGE-ME-long-random-password@oms-db:5432/oms

# ── Sessions (32+ random chars; `openssl rand -hex 32`) ──
SESSION_SECRET=CHANGE-ME-64-hex-chars

# ── Admin panel ──
# Generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1],11))" 'YourPassword'
# (ADMIN_PASSWORD plain-text also works but the hash is strongly preferred.)
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD=

# ── Razorpay (docs/INTEGRATIONS.md §1) ──
# Leave empty until KYC is done. ALLOW_MOCK_PAYMENTS=1 enables the
# "simulate payment" demo button - REMOVE it the day real keys go in.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
ALLOW_MOCK_PAYMENTS=1

# ── Shiprocket (docs/INTEGRATIONS.md §2) ──
# Create an API user in Shiprocket → Settings → API. Empty = manual shipping mode.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary

# ── Email (docs/INTEGRATIONS.md §3) ──
# Default points at the bundled Mailpit viewer (no real mail leaves the server).
# Swap for Brevo: SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587 SMTP_SECURE=0 + user/pass.
SMTP_HOST=oms-mailpit
SMTP_PORT=1025
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SLPL Store <store@theslpl.in>"
OWNER_NOTIFY_EMAIL=saradapublications18@gmail.com

# ── Files ──
UPLOADS_DIR=/app/uploads
